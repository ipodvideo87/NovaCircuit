rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net - Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable, Hardened Global Helper Primitives (Phase 3)
    function isSignedIn() {
      return request.auth != null;
    }

    // Bootstrap verified email conditions
    function isVerifiedUser() {
      return isSignedIn() && (request.auth.token.email_verified == true);
    }

    // Path Variable Hardening
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Context-Aware Payload Helpers
    function incoming() {
      return request.resource.data;
    }

    // Existing Data helper
    function existing() {
      return resource.data;
    }

    // Validation Blueprint (Pillar 2 / Phase 4)
    function isValidProject(data) {
      return data.keys().hasAll(['name', 'ownerId', 'ownerEmail', 'graph', 'createdAt', 'updatedAt'])
        && data.keys().size() <= 10
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.ownerId is string && data.ownerId == request.auth.uid
        && data.ownerEmail is string && data.ownerEmail.size() <= 256
        && data.graph is map
        && (data.componentsCount == null || data.componentsCount is int)
        && (data.tracesCount == null || data.tracesCount is int)
        && (data.isPublic == null || data.isPublic is bool);
    }

    function isOwnerEmail(email) {
      return email == 'spankie837@gmail.com' || email.matches('^[a-zA-Z0-9._%+-]+@firsteda\\.com$');
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'isPro', 'aiActionsThisMonth', 'boardsThisMonth'])
        && data.keys().size() <= 8
        && data.uid is string && data.uid == request.auth.uid
        && data.isPro is bool
        && data.aiActionsThisMonth is int
        && data.boardsThisMonth is int
        && (data.isAdmin == null || data.isAdmin is bool)
        && (data.stripeCustomerId == null || data.stripeCustomerId is string)
        && (data.updatedAt == null || data.updatedAt is string || data.updatedAt is timestamp);
    }

    // Secured projects store paths
    match /projects/{projectId} {
      
      // Guarded target read operations
      allow get: if isValidId(projectId) && (
        existing().isPublic == true || (isSignedIn() && existing().ownerId == request.auth.uid)
      );

      // Secure query evaluation list - client cannot query other users' items
      allow list: if existing().isPublic == true || (isSignedIn() && existing().ownerId == request.auth.uid);

      // Document execution creation (Pillars 1, 11, 13)
      allow create: if isVerifiedUser() 
        && isValidId(projectId) 
        && isValidProject(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      // Rigid action-based state modification update transitions (Pillars 2, 4, 12, 13)
      allow update: if isVerifiedUser() 
        && isValidId(projectId) 
        && isValidProject(incoming())
        && incoming().ownerId == existing().ownerId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && (
          // Action 1: Rename Design
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'updatedAt']) ||
          // Action 2: Mutate Gerber / Schematic Connection Graphs
          incoming().diff(existing()).affectedKeys().hasOnly(['graph', 'componentsCount', 'tracesCount', 'updatedAt']) ||
          // Action 3: Toggle Privacy Controls
          incoming().diff(existing()).affectedKeys().hasOnly(['isPublic', 'updatedAt']) ||
          // Action 4: Absolute general save
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'graph', 'componentsCount', 'tracesCount', 'isPublic', 'updatedAt'])
        );

      // Secure deletion gate
      allow delete: if isVerifiedUser() 
        && isValidId(projectId) 
        && existing().ownerId == request.auth.uid;
    }

    // Secured users profile paths
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUserProfile(incoming())
        && (
          ((incoming().isAdmin == true || incoming().isPro == true) ? isOwnerEmail(request.auth.token.email) : (incoming().isAdmin != true && incoming().isPro != true))
        );

      allow update: if isSignedIn() && request.auth.uid == userId && isValidUserProfile(incoming())
        && (
          isOwnerEmail(request.auth.token.email) || (
            incoming().isPro == existing().isPro
            && (incoming().isAdmin == null || incoming().isAdmin == false)
            && (incoming().aiActionsThisMonth == existing().aiActionsThisMonth + 1 || incoming().aiActionsThisMonth == existing().aiActionsThisMonth)
            && (incoming().boardsThisMonth == existing().boardsThisMonth + 1 || incoming().boardsThisMonth == existing().boardsThisMonth)
          )
        );
      
      allow delete: if false;
    }
  }
}
